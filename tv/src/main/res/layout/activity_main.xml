<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <!-- Status Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@color/bg_status_bar">

        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvIpAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent"
            android:textSize="18sp"
            android:fontFamily="monospace"
            tools:text="192.168.1.50:9090" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            tools:text="Waiting..." />

    </LinearLayout>

    <!-- Received Overlay -->
    <TextView
        android:id="@+id/tvReceivedOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/accent"
        android:textColor="@color/bg_dark"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="12dp"
        android:text="Received! Opening..."
        android:visibility="gone"
        android:gravity="center" />

    <!-- Filter/Search Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="Filter history..."
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:background="@drawable/bg_search_field"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:singleLine="true"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:focusable="true" />

        <Button
            android:id="@+id/btnFavoritesOnly"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:text="★ Favorites"
            android:textSize="14sp"
            android:background="@drawable/bg_button_filter"
            android:textColor="@color/text_primary" />

        <Button
            android:id="@+id/btnBulkSelect"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:text="Select"
            android:textSize="14sp"
            android:background="@drawable/bg_button_filter"
            android:textColor="@color/text_primary" />

        <Button
            android:id="@+id/btnBulkDelete"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:text="Delete Selected"
            android:textSize="14sp"
            android:background="@drawable/bg_button_danger"
            android:textColor="@color/text_primary"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnClearAll"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:text="Clear All"
            android:textSize="14sp"
            android:background="@drawable/bg_button_danger"
            android:textColor="@color/text_primary" />

        <Button
            android:id="@+id/btnExport"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:text="Export"
            android:textSize="14sp"
            android:background="@drawable/bg_button_filter"
            android:textColor="@color/text_primary" />

    </LinearLayout>

    <!-- History RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:focusable="true" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No links received yet"
            android:textColor="@color/text_secondary"
            android:textSize="22sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Send a link from your phone to get started"
            android:textColor="@color/text_hint"
            android:textSize="16sp" />

    </LinearLayout>

</LinearLayout>
